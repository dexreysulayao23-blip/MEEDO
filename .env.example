## MEEDO SMTP settings (Gmail)
## IMPORTANT:
## - Use a Gmail "App Password" (not your normal Gmail password).
## - After editing your .env, RESTART `python app.py`.

MEEDO_SMTP_HOST=smtp.gmail.com
MEEDO_SMTP_PORT=587
MEEDO_SMTP_USER=yourgmail@gmail.com
MEEDO_SMTP_PASS=your_gmail_app_password_here
MEEDO_SMTP_FROM=yourgmail@gmail.com
MEEDO_SMTP_TLS=1

## Optional: dev helper
# MEEDO_DEV=1


## MEEDO SMTP settings (Gmail)
## IMPORTANT:
## - Use a Gmail "App Password" (not your normal Gmail password).
## - After editing this file, RESTART `python app.py`.

MEEDO_SMTP_HOST=smtp.gmail.com
MEEDO_SMTP_PORT=587

# TODO: replace with your Gmail
MEEDO_SMTP_USER=dexreysulayao0@gmail.com

# TODO: replace with your Gmail App Password (16 chars)
MEEDO_SMTP_PASS=abdozrdffgklzwxl

# Sender address (usually same as user)
MEEDO_SMTP_FROM=dexreysulayao0@gmail.com
MEEDO_SMTP_TLS=1

# Enable dev diagnostics (shows email notification failure reason in API response)
MEEDO_DEV=1

